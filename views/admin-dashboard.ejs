<%- include('partials/header', { title: 'Admin Dashboard - Casheew', active: null }) %>

<section class="section">
  <div class="admin-header-row">
    <div>
      <h2 class="section-title">Admin Dashboard</h2>
      <p class="section-subtitle">
        Manage product prices, bulk offers and view daily orders.
      </p>
    </div>
    <div class="admin-actions">
      <form method="get" action="/admin/orders/daily.csv">
        <input
          type="date"
          name="date"
          value="<%= today %>"
          style="padding: 0.25rem 0.35rem; font-size: 0.8rem"
        />
        <button type="submit" class="btn btn-outline" style="padding: 0.35rem 0.8rem">
          Download Daily Orders
        </button>
      </form>
      <a href="/admin/logout" class="link">Logout</a>
    </div>
  </div>

  <div class="form-card">
    <h3 style="margin-bottom: 0.8rem">Shop Contact Details</h3>
    <form method="post" action="/admin/settings/contact">
      <div class="form-grid-2">
        <div class="form-group">
          <label for="shopName">Shop Name</label>
          <input
            type="text"
            id="shopName"
            name="shopName"
            value="<%= (settings && settings.shopName) || 'Casheew Nuts & Dry Fruits' %>"
          />
        </div>
        <div class="form-group">
          <label for="gstin">GSTIN</label>
          <input
            type="text"
            id="gstin"
            name="gstin"
            value="<%= (settings && settings.gstin) || '' %>"
          />
        </div>
        <div class="form-group">
          <label for="phone">Phone / WhatsApp</label>
          <input
            type="text"
            id="phone"
            name="phone"
            value="<%= (settings && settings.phone) || '' %>"
          />
        </div>
        <div class="form-group">
          <label for="email">Email</label>
          <input
            type="email"
            id="email"
            name="email"
            value="<%= (settings && settings.email) || '' %>"
          />
        </div>
        <div class="form-group">
          <label for="address">Address</label>
          <input
            type="text"
            id="address"
            name="address"
            value="<%= (settings && settings.address) || '' %>"
          />
        </div>
        <div class="form-group">
          <label for="whatsappNumber">WhatsApp Number (with country code)</label>
          <input
            type="text"
            id="whatsappNumber"
            name="whatsappNumber"
            value="<%= (settings && settings.whatsappNumber) || '' %>"
          />
          <p class="help-text">
            Example: <strong>919876543210</strong> (no + or spaces). This controls all WhatsApp
            buttons on the website.
          </p>
        </div>
      </div>
      <div class="form-actions">
        <button type="submit" class="btn btn-primary" style="padding: 0.4rem 1.1rem">
          Save Contact Details
        </button>
      </div>
    </form>
  </div>

  <div class="form-card" style="margin-top: 1.5rem">
    <h3 style="margin-bottom: 0.8rem">Payment QR for Customers</h3>
    <div class="form-grid-2">
      <div class="form-group">
        <p class="help-text">
          This QR code will be shown to customers <strong>after they place an order</strong> on
          the confirmation screen. Upload your UPI / bank QR here.
        </p>
        <% if (settings && settings.paymentQrImage) { %>
        <p>
          <strong>Current QR:</strong>
        </p>
        <img
          src="<%= settings.paymentQrImage %>"
          alt="Payment QR"
          style="max-width: 220px; border-radius: 0.6rem; background: #fff"
        />
        <% } else { %>
        <p class="help-text">No QR uploaded yet.</p>
        <% } %>
      </div>

      <div class="form-group">
        <form
          method="post"
          action="/admin/settings/payment-qr"
          enctype="multipart/form-data"
        >
          <label for="qrImage">Upload / Change QR Image</label>
          <input
            type="file"
            id="qrImage"
            name="qrImage"
            accept="image/*"
            required
          />
          <label for="paymentNote" style="margin-top: 0.6rem">Payment Note (optional)</label>
          <input
            type="text"
            id="paymentNote"
            name="paymentNote"
            value="<%= (settings && settings.paymentNote) || '' %>"
            placeholder="Example: UPI: casheew@upi, send payment screenshot on WhatsApp"
          />
          <div class="form-actions" style="margin-top: 0.8rem">
            <button
              type="submit"
              class="btn btn-primary"
              style="padding: 0.35rem 1.1rem"
            >
              Save Payment QR
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <div class="form-card" style="margin-top: 1.5rem">
    <h3 style="margin-bottom: 0.8rem">Products &amp; Pricing</h3>
    <table class="table">
      <thead>
        <tr>
          <th>Product (Name &amp; Short Text)</th>
          <th>Retail ₹/kg</th>
          <th>Wholesale ₹/kg</th>
          <th>Bulk Offer</th>
          <th>Save</th>
        </tr>
      </thead>
      <tbody>
        <% products.forEach(function(p) { %>
        <tr>
          <td>
            <form
              id="product-form-<%= p.id %>"
              method="post"
              action="/admin/products/<%= p.id %>"
            >
              <input
                type="text"
                name="name"
                value="<%= p.name %>"
                style="width: 180px; margin-bottom: 0.25rem"
              /><br />
              <input
                type="text"
                name="description"
                value="<%= p.description || '' %>"
                style="width: 180px; font-size: 0.8rem"
                placeholder="Short description"
              />
          </td>
          <td>
              <input
                type="number"
                name="retailPricePerKg"
                min="0"
                value="<%= p.retailPricePerKg %>"
                style="width: 80px"
              />
          </td>
          <td>
              <input
                type="number"
                name="wholesalePricePerKg"
                min="0"
                value="<%= p.wholesalePricePerKg %>"
                style="width: 80px"
              />
          </td>
          <td>
              <label style="font-size: 0.8rem">
                <input
                  type="checkbox"
                  name="isBulkOffer"
                  value="1"
                  <%= p.isBulkOffer ? 'checked' : '' %>
                />
                Mark as Bulk Offer
              </label>
          </td>
          <td>
              <button
                type="submit"
                class="btn btn-primary"
                style="padding: 0.25rem 0.9rem; font-size: 0.78rem"
              >
                Save Product
              </button>
            </form>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

  <div class="form-card" style="margin-top: 1.5rem">
    <h3 style="margin-bottom: 0.8rem">Product Images</h3>
    <table class="table">
      <thead>
        <tr>
          <th>Product</th>
          <th>Current Image</th>
          <th>Change Image</th>
        </tr>
      </thead>
      <tbody>
        <% products.forEach(function(p) { %>
        <tr>
          <td><strong><%= p.name %></strong></td>
          <td>
            <img
              src="<%= (p.image && p.image.startsWith('/uploads/')) ? p.image : '/images/cashew-hero.png' %>"
              alt="<%= p.name %>"
              style="width: 80px; border-radius: 0.4rem"
            />
          </td>
          <td>
            <form
              method="post"
              action="/admin/products/<%= p.id %>/image"
              enctype="multipart/form-data"
            >
              <input
                type="file"
                name="image"
                accept="image/*"
                style="font-size: 0.8rem; margin-bottom: 0.3rem"
                required
              />
              <button
                type="submit"
                class="btn btn-primary"
                style="padding: 0.25rem 0.9rem; font-size: 0.78rem"
              >
                Upload &amp; Save
              </button>
            </form>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

  <div class="form-card" style="margin-top: 1.5rem">
    <h3 style="margin-bottom: 0.8rem">Add New Product</h3>
    <form method="post" action="/admin/products/new" enctype="multipart/form-data">
      <div class="form-grid-2">
        <div class="form-group">
          <label for="name">Product Name</label>
          <input type="text" id="name" name="name" required />
        </div>
        <div class="form-group">
          <label for="retailPricePerKg">Retail Price (₹ / kg)</label>
          <input type="number" id="retailPricePerKg" name="retailPricePerKg" min="0" step="1" />
        </div>
        <div class="form-group">
          <label for="wholesalePricePerKg">Wholesale Price (₹ / kg)</label>
          <input
            type="number"
            id="wholesalePricePerKg"
            name="wholesalePricePerKg"
            min="0"
            step="1"
          />
        </div>
        <div class="form-group">
          <label for="image">Product Image</label>
          <input type="file" id="image" name="image" accept="image/*" />
        </div>
        <div class="form-group">
          <label for="description">Short Description</label>
          <input type="text" id="description" name="description" />
        </div>
        <div class="form-group">
          <label>
            <input type="checkbox" name="isBulkOffer" value="1" />
            Mark as Bulk Offer
          </label>
        </div>
      </div>
      <div class="form-actions">
        <button type="submit" class="btn btn-primary" style="padding: 0.4rem 1.1rem">
          Add Product
        </button>
      </div>
    </form>
  </div>

  <div class="form-card" style="margin-top: 1.5rem">
    <h3 style="margin-bottom: 0.8rem">Today’s Orders (<%= today %>)</h3>
    <% if (todaysOrders.length === 0) { %>
    <p>No orders received today yet.</p>
    <% } else { %>
    <table class="table">
      <thead>
        <tr>
          <th>Order ID</th>
          <th>Customer</th>
          <th>Type</th>
          <th>Total Kg</th>
          <th>Total ₹</th>
          <th>Status</th>
          <th>Save Status</th>
        </tr>
      </thead>
      <tbody>
        <% todaysOrders.forEach(function(o) { %>
        <tr>
          <td><%= o.id %></td>
          <td>
            <strong><%= o.customerName %></strong><br />
            <span style="font-size: 0.75rem"><%= o.phone %></span>
          </td>
          <td><%= o.orderType === 'wholesale' ? 'Wholesale' : 'Retail' %></td>
          <td><%= o.totalKg %> kg</td>
          <td>₹<%= o.totalPrice.toFixed(2) %></td>
          <td>
            <span class="badge <%= o.status.toLowerCase() %>"><%= o.status %></span>
          </td>
          <td>
            <form method="post" action="/admin/orders/<%= o.id %>/status">
              <select name="status" style="font-size: 0.8rem; padding: 0.25rem 0.35rem">
                <option value="Pending" <%= o.status === 'Pending' ? 'selected' : '' %>>
                  Pending
                </option>
                <option value="Confirmed" <%= o.status === 'Confirmed' ? 'selected' : '' %>>
                  Confirmed
                </option>
                <option value="Dispatched" <%= o.status === 'Dispatched' ? 'selected' : '' %>>
                  Dispatched
                </option>
                <option value="Cancelled" <%= o.status === 'Cancelled' ? 'selected' : '' %>>
                  Cancelled
                </option>
              </select>
              <button
                type="submit"
                class="btn btn-primary"
                style="padding: 0.25rem 0.9rem; font-size: 0.78rem; margin-left: 0.25rem"
              >
                Save Status
              </button>
            </form>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
    <% } %>
  </div>

  <div class="form-card" style="margin-top: 1.5rem">
    <h3 style="margin-bottom: 0.8rem">All Orders (Latest First)</h3>
    <% if (orders.length === 0) { %>
    <p>No orders in the system yet.</p>
    <% } else { %>
    <table class="table">
      <thead>
        <tr>
          <th>Date</th>
          <th>Order ID</th>
          <th>Customer</th>
          <th>Type</th>
          <th>Total Kg</th>
          <th>Total ₹</th>
          <th>Status</th>
        </tr>
      </thead>
      <tbody>
        <% orders.slice().reverse().forEach(function(o) { %>
        <tr>
          <td><%= new Date(o.createdAt).toLocaleDateString() %></td>
          <td><%= o.id %></td>
          <td><%= o.customerName %></td>
          <td><%= o.orderType === 'wholesale' ? 'Wholesale' : 'Retail' %></td>
          <td><%= o.totalKg %> kg</td>
          <td>₹<%= o.totalPrice.toFixed(2) %></td>
          <td>
            <span class="badge <%= o.status.toLowerCase() %>"><%= o.status %></span>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
    <% } %>
  </div>
</section>

<%- include('partials/footer') %>

