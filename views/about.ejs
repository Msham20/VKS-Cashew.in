<%- include('partials/header', { title: 'About Us - Casheew', active: 'about' }) %>

<section class="section">
  <div class="section-header">
    <h2 class="section-title">About Casheew</h2>
    <p class="section-subtitle">
      A small team obsessed with crunchy, clean and premium quality cashews.
    </p>
  </div>

  <div class="form-card">
    <div class="form-group">
      <h3>Our Story</h3>
      <p>
        Casheew is an exclusive cashew nut store focused on delivering fresh, natural and
        handpicked cashews. We work closely with trusted processors and farms to make sure
        every batch that reaches you is <strong>clean, crisp and flavourful</strong>.
      </p>
    </div>

    <div class="form-grid-2">
      <div class="form-group">
        <h3>Shop Details</h3>
        <p>
          <%= (settings && settings.shopName) || 'Casheew Nuts & Dry Fruits' %><br />
          <%= (settings && settings.address) || 'Chennai – 600 001, Tamil Nadu, India.' %>
        </p>
        <p class="help-text">
          Timings: 9:30 AM – 8:30 PM (All days).
        </p>
      </div>

      <div class="form-group">
        <h3>GST &amp; Registration</h3>
        <p>
          GSTIN:
          <strong><%= (settings && settings.gstin) || '33ABCDE1234F1Z5' %></strong><br />
          Registered under Goods &amp; Services Tax, India.
        </p>
        <p class="help-text">
          We provide proper tax invoices for all wholesale orders.
        </p>
      </div>
    </div>

    <div class="form-grid-2">
      <div class="form-group">
        <h3>Contact</h3>
        <p>
          Phone / WhatsApp:
          <strong><%= (settings && settings.phone) || '+91 98765 43210' %></strong><br />
          Email:
          <strong><%= (settings && settings.email) || 'support@casheew.in' %></strong>
        </p>
      </div>

      <div class="form-group">
        <h3>What We Offer</h3>
        <ul class="hero-side-list">
          <li><span class="icon">✔</span>Whole &amp; split cashews (various grades)</li>
          <li><span class="icon">✔</span>Roasted, salted and masala flavours</li>
          <li><span class="icon">✔</span>Bulk packing for retailers &amp; brands</li>
          <li><span class="icon">✔</span>Corporate and festive gifting packs</li>
        </ul>
      </div>
    </div>
  </div>
</section>

<%- include('partials/footer') %>

